#!/usr/bin/env fish
eval "$(/opt/homebrew/bin/brew shellenv)"
# brew bundle --no-lock --file=~/Brewfile
echo '
{{ range .core.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .core.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .core.casks -}}
cask {{ . | quote }}
{{ end -}}


{{ range .utilities.brews -}}
brew {{ . | quote }}
{{ end -}}

{{ range .ide.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ range .ide.vscodes -}}
vscode {{ . | quote }}
{{ end -}}


' | brew bundle --no-lock --file=/dev/stdin
